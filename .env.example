# Copy to .env and fill in real values. Loaded by src/shared/config/config.ts via Deno.env.
# (Deno does not auto-load .env files; export these or use `deno run --env-file=.env` when running.)

# Runtime environment: development | test | production
APP_ENV=development

# HTTP + WebSocket bind address
HOST=0.0.0.0
PORT=8080

# SQLite database file path (relative to project root, or absolute)
DATABASE_PATH=./storage/database/centrumchat.sqlite

# Upload root on disk. Files land under MEDIA_ROOT in per-kind subfolders:
# profile/ (avatars), cover/ (covers), attachments/ (message uploads).
MEDIA_ROOT=./storage

# Extra browser origins allowed for CORS / WebSocket Origin checks, comma-separated.
# Same-origin requests are always allowed even when this is blank.
ALLOWED_ORIGINS=

# JWT signing secret for access tokens (HS256). Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# Public browser-facing base URL used in verification/reset/email-change mails.
# Production must set this explicitly to the HTTPS origin users actually visit.
PUBLIC_BASE_URL=http://localhost:8080

# Access token lifetime, in seconds (default 15 minutes)
ACCESS_TOKEN_TTL_SECONDS=900

# Refresh-session lifetime when rememberMe=false (default 24 hours)
SESSION_DEFAULT_TTL_MS=86400000

# Refresh-session lifetime when rememberMe=true (default 30 days)
SESSION_REMEMBERED_TTL_MS=2592000000

# One-time account-security token lifetimes
EMAIL_VERIFICATION_TTL_MS=3600000
PASSWORD_RESET_TTL_MS=1800000
EMAIL_CHANGE_TTL_MS=3600000

# Mail delivery adapter: development | resend
MAIL_ADAPTER=development

# Sender details used by the configured mail adapter
MAIL_FROM_ADDRESS=noreply@example.invalid
MAIL_FROM_NAME=CentrumChat

# Required when MAIL_ADAPTER=resend
RESEND_API_KEY=

# Minimum log level: debug | info | warn | error
LOG_LEVEL=info

# Max upload size in bytes for /api/media/upload (default 25MB)
MAX_ATTACHMENT_SIZE_BYTES=26214400

# Max upload size in bytes for /api/media/avatar (default 5MB)
MAX_AVATAR_SIZE_BYTES=5242880

# Max upload size in bytes for /api/media/cover (default 5MB)
MAX_COVER_SIZE_BYTES=5242880

# Maximum inbound WebSocket text payload size in bytes
MAX_WS_MESSAGE_BYTES=65536

# Close a WebSocket after this many malformed/oversized protocol violations
WS_PROTOCOL_ERROR_LIMIT=3

# Transport-level inbound WebSocket message rate limit per connection
WS_INBOUND_RATE_LIMIT_MAX_TOKENS=120
WS_INBOUND_RATE_LIMIT_REFILL_INTERVAL_MS=10000

# Concurrent authenticated WebSocket connections allowed per user and peer IP
WS_MAX_CONNECTIONS_PER_USER=5
WS_MAX_CONNECTIONS_PER_IP=25

# Close a slow client once the browser/server-side websocket has this many outbound bytes buffered
WS_MAX_BUFFERED_AMOUNT_BYTES=1048576

# Application-level WebSocket heartbeat cadence and stale-connection timeout
WS_HEARTBEAT_INTERVAL_MS=30000
WS_IDLE_TIMEOUT_MS=90000

# Assert that the public deployment is HTTPS. HSTS is emitted only when APP_ENV=production and this is true.
PUBLIC_HTTPS=false

# Periodic user-session cleanup interval in milliseconds (default 6 hours)
SESSION_CLEANUP_INTERVAL_MS=21600000

# How long revoked sessions are retained before cleanup, in milliseconds (default 30 days)
REVOKED_SESSION_RETENTION_MS=2592000000
# CAPTCHA: development, turnstile, or none (none disables CAPTCHA).
CAPTCHA_ADAPTER=development
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=
CAPTCHA_EXPECTED_HOSTNAME=localhost

# Initial owner bootstrap. Register the account first, then restart with this value set.
# Promotion occurs only when no owner exists and the normalized account already exists.
BOOTSTRAP_OWNER_EMAIL=
